{
  "name": "@repoatlasdev/exporters",
  "version": "0.1.0",
  "description": "Multi-format exporter plugins for RepoAtlas project trees (HTML, Markdown, SVG, Mermaid, DOCX, PDF, CSV, etc.)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akshaykumar33/RepoAtlas.git",
    "directory": "packages/exporters"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@repoatlasdev/core": "workspace:*",
    "@repoatlasdev/renderers": "workspace:*",
    "@repoatlasdev/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vitest": "^1.4.0"
  }
}
