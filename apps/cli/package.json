{
  "name": "@repoatlasdev/cli",
  "version": "0.2.1",
  "description": "Professional Commander.js CLI suite for RepoAtlas visual tree generation and diagnostics",
  "type": "module",
  "bin": {
    "repo-atlas": "./dist/index.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akshaykumar33/RepoAtlas.git",
    "directory": "apps/cli"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@repoatlasdev/config": "workspace:*",
    "@repoatlasdev/core": "workspace:*",
    "@repoatlasdev/icons": "workspace:*",
    "@repoatlasdev/renderers": "workspace:*",
    "@repoatlasdev/utils": "workspace:*",
    "commander": "^12.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vitest": "^1.4.0"
  }
}
